---
export interface Props {
  accept: string;              // <input accept> value, e.g. ".md,.markdown,.txt"
  extPattern: string;          // regex source (no slashes) for client-side validation
  outputExt: string;           // ".docx" or ".md"
  dropTitle: string;           // "Drop your Markdown files here"
  dropFormats: string;         // ".md, .markdown, .txt"
  convertLabelSingle: string;  // "Convert to DOCX" / "Convert to Markdown"
  otherFormat?: {
    label: string;   // "Word" / "Markdown"
    href: string;     // "/docx-to-md/" or "/"
    pattern: string;  // regex source matching the OTHER tool's extensions
  };
}

const {
  accept,
  extPattern,
  outputExt,
  dropTitle,
  dropFormats,
  convertLabelSingle,
  otherFormat,
} = Astro.props;

const API_URL = import.meta.env.PUBLIC_API_URL;
const MAX_FILE_MB = 25;
---

<div class="card">
  <div class="warn" id="backendWarn">
    <svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
      <line x1="12" y1="9" x2="12" y2="13"/>
      <line x1="12" y1="17" x2="12.01" y2="17"/>
    </svg>
    <div id="backendWarnText">Checking conversion service&hellip;</div>
  </div>

  <label class="drop" id="drop">
    <input type="file" id="file" accept={accept} multiple />
    <div class="drop-icon">
      <svg aria-hidden="true" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="17 8 12 3 7 8"/>
        <line x1="12" y1="3" x2="12" y2="15"/>
      </svg>
    </div>
    <div>
      <div class="drop-title">{dropTitle}</div>
      <div class="drop-hint">or <span class="browse">browse from your computer</span> · {dropFormats} · max {MAX_FILE_MB} MB each · single or bulk</div>
    </div>
  </label>

  <div class="file-summary" id="fileSummary">
    <span id="fileSummaryText">0 files selected</span>
    <button type="button" class="clear-all" id="clearAllBtn">Clear all</button>
  </div>

  <div class="file-list" id="fileList"></div>

  <div class="progress" id="progress"><div class="progress-bar"></div></div>

  <div class="status" id="status"></div>

  <div class="actions" id="actions" style="display:none;">
    <button type="button" class="btn" id="addMoreBtn">+ Add more files</button>
    <button type="button" class="btn" id="resetBtn">Reset</button>
    <button type="button" class="btn primary" id="convertBtn">{convertLabelSingle}</button>
  </div>
</div>

<style>
  @reference "../styles/global.css";

  .card {
    @apply bg-canvas border border-hairline rounded-lg p-8;
    box-shadow: 0 1px 3px rgba(20,20,19,0.08);
  }

  .warn {
    @apply hidden gap-2.5 items-start bg-warning/10 border border-warning/35 text-warning px-3.5 py-3 rounded-lg text-[13px] mb-4 leading-snug;
  }
  .warn.show { @apply flex; }
  .warn code { @apply font-mono bg-black/10 px-1.5 py-0.5 rounded text-xs; }

  .drop {
    @apply relative flex flex-col items-center justify-center gap-3 text-center px-5 py-11 border-2 border-dashed border-hairline rounded-xl bg-surface-soft cursor-pointer;
    transition: border-color .18s, background-color .18s;
  }
  .drop:hover { @apply border-primary/50; }
  .drop.drag { @apply border-primary bg-primary/10; }
  .drop input { @apply hidden; }
  .drop-icon {
    @apply w-13 h-13 rounded-lg grid place-items-center bg-primary/15 border border-primary/30 text-primary;
  }
  .drop-title { @apply text-base font-medium text-ink; }
  .drop-hint { @apply text-muted text-[13px] mt-1; }
  .browse { @apply text-primary underline underline-offset-2 font-semibold; }

  .file-summary {
    @apply hidden items-center justify-between mt-3.5 px-0.5 text-muted text-xs tracking-wide uppercase font-semibold;
  }
  .file-summary.show { @apply flex; }
  .file-summary .clear-all { @apply text-primary underline underline-offset-2 cursor-pointer normal-case tracking-normal font-semibold bg-transparent border-0 p-0 font-sans text-xs; }

  .file-list { @apply flex flex-col gap-2 mt-2 max-h-64 overflow-y-auto; }

  .file {
    @apply flex items-center gap-3 bg-surface-card/60 border border-hairline rounded-lg px-3.5 py-3;
  }
  .file-icon { @apply w-9 h-9 rounded-md bg-primary/15 text-primary grid place-items-center shrink-0; }
  .file-meta { @apply min-w-0 flex-1; }
  .file-name { @apply text-sm font-medium whitespace-nowrap overflow-hidden text-ellipsis text-ink; }
  .file-size { @apply text-muted text-xs mt-0.5; }
  .file-remove {
    @apply shrink-0 w-7 h-7 rounded-md grid place-items-center border border-hairline bg-transparent text-muted cursor-pointer;
    transition: background-color .15s, color .15s, border-color .15s;
  }
  .file-remove:hover { @apply bg-error/10 border-error/35 text-error; }

  .progress { @apply hidden mt-3.5 h-1.5 bg-surface-card rounded-full overflow-hidden; }
  .progress.show { @apply block; }
  .progress-bar {
    height: 100%;
    width: 30%;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-primary-active));
    animation: slide 1.2s ease-in-out infinite;
  }
  @keyframes slide {
    0%   { margin-left: -30%; }
    100% { margin-left: 100%; }
  }
  @media (prefers-reduced-motion: reduce) {
    .progress-bar { animation: none; width: 100%; }
  }

  .status { @apply hidden items-center gap-2.5 mt-3.5 px-3.5 py-3 rounded-lg text-sm leading-snug; }
  .status.show { @apply flex; }
  .status.ok  { @apply bg-success/10 border border-success/35 text-success; }
  .status.err { @apply bg-error/10 border border-error/35 text-error; }
  .status svg { @apply shrink-0; }
  .status :global(a) { @apply text-primary underline underline-offset-2 font-semibold; }

  .actions { @apply flex gap-2.5 mt-4.5; }
  .btn {
    @apply flex-1 px-4 py-3 rounded-md border border-hairline bg-canvas text-ink text-sm font-medium cursor-pointer;
    transition: background-color .15s, border-color .15s, transform .05s;
  }
  .btn:hover { @apply bg-surface-card; }
  .btn:active { transform: translateY(1px); }
  .btn.primary { @apply bg-primary border-transparent text-on-primary; }
  .btn.primary:hover { @apply bg-primary-active; }
  .btn:disabled { @apply opacity-45 cursor-not-allowed; }
  .btn:focus-visible,
  .file-remove:focus-visible,
  .clear-all:focus-visible {
    @apply outline-none ring-2 ring-primary/50 ring-offset-2 ring-offset-canvas;
  }
  .drop:has(input:focus-visible) {
    @apply outline-none ring-2 ring-primary/50 ring-offset-2 ring-offset-canvas;
  }

  @media (max-width: 480px) {
    .card { @apply p-5; }
    .drop { @apply px-3.5 py-8; }
  }
</style>

<script define:vars={{ API_URL, MAX_FILE_MB, extPattern, outputExt, otherFormat }}>
  const drop = document.getElementById('drop');
  const input = document.getElementById('file');
  const fileSummary = document.getElementById('fileSummary');
  const fileSummaryText = document.getElementById('fileSummaryText');
  const clearAllBtn = document.getElementById('clearAllBtn');
  const fileList = document.getElementById('fileList');
  const status = document.getElementById('status');
  const progress = document.getElementById('progress');
  const actions = document.getElementById('actions');
  const convertBtn = document.getElementById('convertBtn');
  const resetBtn = document.getElementById('resetBtn');
  const addMoreBtn = document.getElementById('addMoreBtn');
  const backendWarn = document.getElementById('backendWarn');
  const backendWarnText = document.getElementById('backendWarnText');

  const MAX_FILE_BYTES = MAX_FILE_MB * 1024 * 1024;
  const extRe = new RegExp(extPattern, 'i');
  const otherExtRe = otherFormat ? new RegExp(otherFormat.pattern, 'i') : null;
  const convertLabelSingle = convertBtn.textContent;
  let currentFiles = [];
  let backendOk = false;

  const fmtSize = (b) => {
    if (b < 1024) return b + ' B';
    if (b < 1024*1024) return (b/1024).toFixed(1) + ' KB';
    return (b/1024/1024).toFixed(2) + ' MB';
  };

  const showStatus = (html, cls) => {
    status.className = 'status show ' + cls;
    status.innerHTML = html;
  };
  const clearStatus = () => { status.className = 'status'; status.innerHTML = ''; };

  const iconOk = '<svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
  const iconErr = '<svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>';
  const fileSvg = '<svg aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>';
  const xSvg = '<svg aria-hidden="true" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';

  const isDuplicate = (file) => currentFiles.some(
    f => f.name === file.name && f.size === file.size && f.lastModified === file.lastModified
  );

  const render = () => {
    const n = currentFiles.length;
    if (n === 0) {
      fileSummary.classList.remove('show');
      fileList.innerHTML = '';
      actions.style.display = 'none';
      return;
    }
    fileSummary.classList.add('show');
    const totalSize = currentFiles.reduce((sum, f) => sum + f.size, 0);
    fileSummaryText.textContent = `${n} file${n > 1 ? 's' : ''} selected · ${fmtSize(totalSize)} total`;

    fileList.innerHTML = currentFiles.map((f, i) => `
      <div class="file">
        <div class="file-icon">${fileSvg}</div>
        <div class="file-meta">
          <div class="file-name">${f.name}</div>
          <div class="file-size">${fmtSize(f.size)}</div>
        </div>
        <button type="button" class="file-remove" data-idx="${i}" title="Remove" aria-label="Remove ${f.name}">${xSvg}</button>
      </div>
    `).join('');

    actions.style.display = 'flex';
    convertBtn.disabled = !backendOk;
    convertBtn.textContent = n > 1 ? `Convert ${n} files (ZIP)` : convertLabelSingle;
  };

  const pickFiles = (fileArr) => {
    const errors = [];
    for (const file of fileArr) {
      if (!extRe.test(file.name)) {
        if (otherExtRe && otherExtRe.test(file.name)) {
          errors.push(`${file.name}: that looks like a ${otherFormat.label} file — try our <a href="${otherFormat.href}">other converter</a>`);
        } else {
          errors.push(`${file.name}: unsupported type`);
        }
        continue;
      }
      if (file.size > MAX_FILE_BYTES) { errors.push(`${file.name}: too large`); continue; }
      if (isDuplicate(file)) continue;
      currentFiles.push(file);
    }
    if (errors.length) {
      showStatus(iconErr + '<span>' + errors.join('<br>') + '</span>', 'err');
    } else {
      clearStatus();
    }
    render();
  };

  const reset = () => {
    currentFiles = [];
    input.value = '';
    progress.classList.remove('show');
    clearStatus();
    render();
  };

  fileList.addEventListener('click', (e) => {
    const btn = e.target.closest('.file-remove');
    if (!btn) return;
    currentFiles.splice(Number(btn.dataset.idx), 1);
    render();
  });

  drop.addEventListener('dragover', e => { e.preventDefault(); drop.classList.add('drag'); });
  drop.addEventListener('dragleave', () => drop.classList.remove('drag'));
  drop.addEventListener('drop', e => {
    e.preventDefault(); drop.classList.remove('drag');
    if (e.dataTransfer.files.length) pickFiles([...e.dataTransfer.files]);
  });
  input.addEventListener('change', () => {
    if (input.files.length) pickFiles([...input.files]);
    input.value = '';
  });
  resetBtn.addEventListener('click', reset);
  clearAllBtn.addEventListener('click', reset);
  addMoreBtn.addEventListener('click', () => input.click());

  convertBtn.addEventListener('click', async () => {
    if (!currentFiles.length) return;
    convertBtn.disabled = true;
    resetBtn.disabled = true;
    progress.classList.add('show');
    clearStatus();

    const fd = new FormData();
    for (const f of currentFiles) fd.append('files', f);

    const isBulk = currentFiles.length > 1;
    const singleOutName = !isBulk ? currentFiles[0].name.replace(extRe, outputExt) : null;

    try {
      const res = await fetch(`${API_URL}/convert`, { method: 'POST', body: fd });
      if (!res.ok) {
        const err = await res.json().catch(() => ({error: 'Conversion failed'}));
        showStatus(iconErr + '<span>' + (err.error || 'Conversion failed') + '</span>', 'err');
        return;
      }
      const blob = await res.blob();
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      const outName = isBulk ? 'converted-files.zip' : singleOutName;
      a.href = url;
      a.download = outName;
      a.click();
      URL.revokeObjectURL(url);
      const msg = isBulk
        ? `<b>${currentFiles.length} files</b> converted — <b>${outName}</b> downloaded.`
        : `<b>${outName}</b> downloaded.`;
      showStatus(iconOk + '<span>' + msg + '</span>', 'ok');
    } catch (e) {
      showStatus(iconErr + '<span>Network error: ' + e.message + '</span>', 'err');
    } finally {
      progress.classList.remove('show');
      convertBtn.disabled = !backendOk;
      resetBtn.disabled = false;
    }
  });

  (async () => {
    try {
      const res = await fetch(`${API_URL}/health`);
      const data = await res.json();
      backendOk = !!data.pandoc;
      if (!backendOk) {
        backendWarn.classList.add('show');
        backendWarnText.textContent = 'Conversion service is up but Pandoc is not available. Try again later.';
      }
    } catch (e) {
      backendOk = false;
      backendWarn.classList.add('show');
      backendWarnText.textContent = 'Conversion service is unreachable. Try again in a moment.';
    }
    convertBtn.disabled = !backendOk || currentFiles.length === 0;
  })();
</script>
