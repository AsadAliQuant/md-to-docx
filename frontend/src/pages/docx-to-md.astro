---
import '../styles/global.css';
import ConverterWidget from '../components/ConverterWidget.astro';
import PageSections from '../components/PageSections.astro';

const SITE = 'https://free-md-to-docx.pages.dev';

const faqs = [
  {
    q: 'Is this actually free?',
    a: 'Yes — every conversion is free, with no signup, no watermark, and no hidden per-file limit beyond the size caps below.',
  },
  {
    q: 'Where are my files processed — is it private?',
    a: "Your files are uploaded over HTTPS to our conversion server and processed there with Pandoc — this isn't a browser-only tool. We don't read, inspect, or store the contents of your documents. Uploaded source files are deleted the moment conversion finishes, and the converted output is removed right after your download completes. If you're converting something highly sensitive, running Pandoc locally on your own machine is the safest option.",
  },
  {
    q: 'What happens to complex Word formatting?',
    a: "Markdown is a much simpler format than .docx, so it can't represent everything Word can. Headings, paragraphs, bold/italic, lists, tables, block quotes, and links all convert cleanly. Things like custom fonts, colors, comments, tracked changes, and precise page layout don't have a Markdown equivalent and won't carry over — the output focuses on structure and content, not visual styling.",
  },
  {
    q: 'What about images inside my Word document?',
    a: "In this version, images embedded in a .docx aren't extracted into the converted Markdown — the text, headings, tables, and links convert, but inline images are omitted. If your document is image-heavy, keep the original .docx as your source of truth for those. (Full image extraction is on our roadmap.)",
  },
  {
    q: 'Is there a file size limit?',
    a: 'Each file can be up to 25 MB, and a single upload batch can total up to 200 MB.',
  },
  {
    q: 'Can I convert more than one file at once?',
    a: "Yes. Drop as many .docx files as you like in a single batch; more than one file comes back as a single .zip. Plenty of similar tools cap you at one file at a time — this one doesn't.",
  },
  {
    q: 'Can I use the converted Markdown commercially?',
    a: "Yes. The output is plain text with no license restrictions attached — it's entirely yours to use, edit, publish, or sell.",
  },
  {
    q: 'Will the Markdown look exactly like my Word document?',
    a: 'Not visually — Markdown has no visual styling of its own; how it looks depends on wherever you render it (GitHub, a static site, an editor preview). What carries over is the structure: headings stay headings, lists stay lists, tables stay tables.',
  },
];
---

<html lang="en">
<head>
<meta charset="utf-8" />
<title>Word to Markdown Converter — Free .docx to .md | md-to-docx</title>
<meta name="description" content="Convert Word (.docx) documents to Markdown (.md) online, free. Drag, drop, and batch-convert — powered by Pandoc, no signup, no file limit." />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="canonical" href={`${SITE}/docx-to-md/`} />
<meta name="generator" content={Astro.generator} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<meta property="og:type" content="website" />
<meta property="og:site_name" content="md-to-docx" />
<meta property="og:title" content="Word to Markdown Converter — Free & Instant" />
<meta property="og:description" content="Convert Word documents to Markdown online, free. Drag and drop single or bulk .docx files — powered by Pandoc, no signup." />
<meta property="og:url" content={`${SITE}/docx-to-md/`} />
<meta property="og:image" content={`${SITE}/og-image.png`} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="Word to Markdown Converter — Free & Instant" />
<meta name="twitter:description" content="Convert Word documents to Markdown online, free — powered by Pandoc, no signup." />
<meta name="twitter:image" content={`${SITE}/og-image.png`} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "md-to-docx — Word to Markdown Converter",
  "url": `${SITE}/docx-to-md/`,
  "applicationCategory": "Utility",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "description": "Free online tool to convert Word (.docx) documents to Markdown (.md), powered by Pandoc. Supports single files and bulk batches.",
  "featureList": [
    "Convert .docx to clean Markdown",
    "Bulk / batch conversion with ZIP download",
    "No signup or account required",
    "Powered by Pandoc",
  ],
})} />

<style>
  @reference "../styles/global.css";
  * { box-sizing: border-box; }
  html, body { height: 100%; }
  body {
    @apply m-0 text-ink bg-canvas flex flex-col items-center p-6 antialiased;
  }

  .app { width: 100%; max-width: 640px; }

  .brand {
    @apply flex items-center gap-3 justify-center mb-5 text-muted text-[13px] tracking-wide uppercase font-semibold;
  }
  .brand-dot { @apply w-2 h-2 rounded-full bg-primary; }

  h1 {
    @apply font-display font-medium text-[28px] leading-tight tracking-[-0.3px] mb-1.5 text-ink;
  }
  .sub { @apply text-body mb-6 text-sm leading-relaxed; }
  .sub code { @apply font-mono text-[13px] bg-surface-card px-1.5 py-0.5 rounded; }

  .footer { @apply mt-4.5 text-center text-muted text-xs; }
  .footer .dot { @apply opacity-50 mx-1.5; }
  .footer a { @apply text-primary underline underline-offset-2 font-semibold; }

  @media (max-width: 480px) {
    h1 { @apply text-xl; }
  }
</style>
</head>
<body>
  <div class="app">
    <div class="brand">
      <span class="brand-dot"></span>
      <span>md-to-docx</span>
    </div>

    <h1>Convert Word to Markdown</h1>
    <p class="sub">Drop in one .docx file or a whole batch. Headings, lists, tables, and links come out the other side as clean, portable Markdown — ready for a README, a static site, or your notes app.</p>

    <ConverterWidget
      accept=".docx"
      extPattern="\.docx$"
      outputExt=".md"
      dropTitle="Drop your Word files here"
      dropFormats=".docx"
      convertLabelSingle="Convert to Markdown"
      otherFormat={{ label: 'Markdown', href: '/', pattern: '\\.(md|markdown|txt)$' }}
    />

    <div class="footer">
      Free &amp; unlimited <span class="dot">·</span> Powered by Pandoc <span class="dot">·</span> No signup
      <span class="dot">·</span> Need the reverse? <a href="/">Convert Markdown to Word →</a>
    </div>

    <PageSections
      howItWorksTitle="How it works"
      steps={[
        { title: 'Drop your Word files', body: 'Drag one or many .docx files into the box above, or click to browse.' },
        { title: 'Pandoc rebuilds it as Markdown', body: "Your files go to our conversion service, where Pandoc reads the Word document's structure and rewrites it as plain-text Markdown — headings become #, tables become pipe tables, and so on." },
        { title: 'Download your .md', body: 'A single file downloads immediately. Batches come back as one .zip.' },
      ]}
      benefitsTitle="Built for taking your writing out of Word and into plain text"
      benefitsIntro="md-to-docx converts Word (.docx) documents to Markdown using Pandoc, the standard open-source document converter — upload one file or a whole batch, and headings, paragraphs, lists, tables, and links all come through as clean, editable Markdown."
      benefits={[
        { title: 'Batch conversion, not one-at-a-time', body: "Upload a folder's worth of .docx files together. Several similar tools only let you convert one file at a time — this one doesn't." },
        { title: 'Nothing to install', body: 'No pandoc install, no command line, no Word plugin. Open a browser tab, drop your files, done.' },
        { title: 'Clean, portable output', body: 'You get plain-text Markdown you can commit to a repo, paste into a static site generator, or open in any editor — no Word required to read it again.' },
        { title: 'No account, no watermark', body: "We don't ask for an email address, and nothing is stamped into your output." },
        { title: 'Open-source engine underneath', body: 'Conversion runs on Pandoc, the same tool technical writers and academic publishers have trusted for two decades — not a black-box in-house parser.' },
        { title: "Your files don't linger", body: 'Uploaded files are removed the moment conversion finishes, and converted output is deleted right after your download completes.' },
      ]}
      useCasesTitle="Who this is for"
      useCases={[
        { title: 'Migrating docs to a wiki or static site', body: 'Bring existing Word documentation into a Markdown-based wiki, docs site, or static site generator without retyping everything.' },
        { title: 'Cleaning up client deliverables', body: 'Received a spec, brief, or contract as a .docx? Convert it to Markdown to diff it, version it in git, or paste it into a Markdown editor.' },
        { title: 'Notes & knowledge bases', body: 'Move old Word notes into Obsidian, Notion-flavored Markdown, or a personal knowledge base.' },
        { title: 'README and changelog migration', body: 'Turn a Word-based README or changelog into the Markdown format GitHub and GitLab expect.' },
        { title: 'Content repurposing', body: 'Convert an article drafted in Word into Markdown for a blog, CMS, or newsletter platform that expects plain text.' },
        { title: 'Version control for prose', body: "Markdown diffs cleanly in git; Word docs don't. Convert once and start tracking every future edit as plain text." },
      ]}
      faqTitle="Frequently asked questions"
      faqs={faqs}
    />
  </div>
</body>
</html>
